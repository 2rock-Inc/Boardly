--swiftversion 6.0
--indent 4
--maxwidth 140
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--closingparen same-line
--self remove
--importgrouping testable-bottom
--exclude .build,DerivedData,Reference

# Keep concise single-line bodies (e.g. `var id: String { rawValue }`) rather
# than expanding them onto multiple lines — the idiomatic Swift/SwiftUI style.
--disable wrapFunctionBodies,wrapPropertyBodies,wrapLoopBodies

